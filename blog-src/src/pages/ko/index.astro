---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const base = import.meta.env.BASE_URL;
const site = 'https://fairpass.world';

const allPosts = await getCollection('blog-ko', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [...new Set(posts.map(p => p.data.category))];
---

<BlogLayout
  title="한국어 블로그 — 행사 운영 인사이트"
  description="기업·기관 행사 담당자를 위한 접수 자동화, 현장 체크인, 친환경 명찰 운영 가이드. FAIRPASS가 제공합니다."
  lang="ko"
  hreflangKo={`${site}${base}/ko/`}
  hreflangEn={`${site}${base}/en/`}
  canonicalURL={`${site}${base}/ko/`}
  type="website"
>
  <!-- Breadcrumb slot -->
  <Fragment slot="breadcrumb">
    <span>/</span>
    <span class="text-fp-text">한국어</span>
  </Fragment>

  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold mb-3">
        <span class="bg-gradient-to-r from-fp-purple-light to-fp-cyan-light bg-clip-text text-transparent">
          행사 운영 인사이트
        </span>
      </h1>
      <p class="text-fp-muted text-sm">
        기업·기관 행사 담당자를 위한 접수, 체크인, 명찰 운영 실무 가이드
      </p>
    </div>

    <!-- Category filter (static) -->
    {categories.length > 1 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {categories.map(cat => (
          <span class="text-xs px-3 py-1.5 rounded-full border border-fp-border text-fp-muted hover:border-fp-purple hover:text-fp-purple-light transition-all cursor-default">
            {cat}
          </span>
        ))}
      </div>
    )}

    <!-- Posts grid -->
    {posts.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            lang="ko"
          />
        ))}
      </div>
    ) : (
      <p class="text-fp-muted text-sm">포스트를 준비 중입니다.</p>
    )}
  </div>
</BlogLayout>
