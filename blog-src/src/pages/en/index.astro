---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const base = import.meta.env.BASE_URL;
const site = 'https://fairpass.world';

const allPosts = await getCollection('journal-en', ({ data }) => !data.draft && data.status === 'published');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [...new Set(posts.map(p => p.data.category))];
---

<BlogLayout
  title="FAIRPASS Journal — Event Management Insights"
  description="Practical guides for event managers: registration automation, self-service check-in kiosks, and eco-friendly name badges. By FAIRPASS."
  lang="en"
  hreflangKo={`${site}${base}/ko/`}
  hreflangEn={`${site}${base}/en/`}
  canonicalURL={`${site}${base}/en/`}
  type="website"
>
  <Fragment slot="breadcrumb">
    <span>/</span>
    <span class="text-fp-text">English</span>
  </Fragment>

  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold mb-3">
        <span class="bg-gradient-to-r from-fp-purple-light to-fp-cyan-light bg-clip-text text-transparent">
          Event Management Insights
        </span>
      </h1>
      <p class="text-fp-muted text-sm">
        Practical guides for corporate event managers — registration, check-in, badges, and more.
      </p>
    </div>

    {categories.length > 1 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {categories.map(cat => (
          <span class="text-xs px-3 py-1.5 rounded-full border border-fp-border text-fp-muted cursor-default">
            {cat}
          </span>
        ))}
      </div>
    )}

    {posts.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            lang="en"
          />
        ))}
      </div>
    ) : (
      <p class="text-fp-muted text-sm">Posts coming soon.</p>
    )}
  </div>
</BlogLayout>
